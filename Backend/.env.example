PORT=3000
WS_PORT=8080
NODE_ENV=development

# URL publique HTTPS du backend (Unity / clients distants). Vide en local : Unity utilisera httpPort du message WS ou le scan 127.0.0.1.
PUBLIC_HTTP_BASE=

TIKTOK_USERNAME=your_tiktok_username
TIKTOK_USERNAMES=your_tiktok_username,backup_tiktok_username
TIKTOK_RETRY_MS=15000
OPENAI_API_KEY=your_openai_api_key

# --- OAuth providers (Unity profile sync) ---
# Mets ici l'URL d'auth de ton backend OAuth / provider relay.
# Le serveur expose:
#  - GET /auth/providers
#  - GET /auth/:provider/start
#  - GET /auth/:provider/callback
#  - POST /profile/sync
OAUTH_TIKTOK_URL=
OAUTH_GOOGLE_URL=
OAUTH_FACEBOOK_URL=
# Durée de vie d'un profil OAuth en cache (ms), ex: 12h
OAUTH_PROFILE_TTL_MS=43200000

# --- TTS (Unity → POST /tts) : privilégier le PCM ---
# Par défaut, le backend utilise le TTS Microsoft Edge (gratuit, pas de clé) → PCM 24 kHz pour Unity.
# Désactiver : TTS_EDGE_ENABLED=0
# Voix (liste : voir https://github.com/ericc-ch/edge-tts) :
# TTS_EDGE_VOICE=fr-FR-DeniseNeural
#
# Le client Unity envoie toujours prefer_pcm=1 (form urlencoded). Le backend tente alors surtout du PCM
# (évite le décodage MP3 dans Unity / Windows « Unable to read data »).
#
# OpenAI (payant) : OPENAI_API_KEY → OpenAI renvoie du PCM 24 kHz (pas de MP3) si Edge est désactivé ou en repli.
# ElevenLabs : si ELEVENLABS_API_KEY + ELEVENLABS_VOICE_ID sont définis, ElevenLabs est essayé en premier ;
# garde ELEVENLABS_OUTPUT_FORMAT=pcm_22050 (ou pcm_16000) pour rester en PCM quand prefer_pcm=1 côté Unity.
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy

# ElevenLabs : voix autorisée sur ton compte (clone ou plan).
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=pcm_22050
